C) Get, Set, Add, Remove, CSS Classes in jQuery
Code:-

<!DOCTYPE html>
<html>
<head>

<title>jQuery Classes Example</title>

<!-- jQuery CDN -->
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>

<script>

$(document).ready(function(){

    // Get text
    $("#get").click(function(){
        alert($("#text").text());
    });

    // Set text
    $("#set").click(function(){
        $("#text").text("Text changed using jQuery");
    });

    // Add CSS class
    $("#add").click(function(){
        $("#text").addClass("highlight");
    });

    // Remove CSS class
    $("#remove").click(function(){
        $("#text").removeClass("highlight");
    });

});

</script>

<style>

.highlight{
color:white;
background-color:blue;
font-size:20px;
padding:5px;
}

</style>

</head>

<body>

<h2>jQuery Get, Set, Add, Remove CSS Classes</h2>

<p id="text">This is a sample text</p>

<button id="get">Get Text</button>
<button id="set">Set Text</button>
<button id="add">Add Class</button>
<button id="remove">Remove Class</button>

</body>
</html>

