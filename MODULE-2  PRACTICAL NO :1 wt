AIM:- Java Script Events and Event Handlers: 
a) Write a simple client-side script that changes page content to introduce Static and dynamic web pages.
Code:-
<!DOCTYPE html>
<html>
<head>
    <title>Static vs Dynamic Web Page</title>
    <style>
        body {
            font-family: Arial;
            text-align: center;
            margin-top: 50px;
        }
        button {
            padding: 10px 20px;
            margin: 10px;
            font-size: 16px;
        }
        #content {
            margin-top: 20px;
            font-size: 18px;
            color: darkblue;
        }
    </style>
</head>
<body>

    <h1>Web Pages Example</h1>

    <p id="content">
        Click a button to learn about Static or Dynamic Web Pages.
    </p>

    <!-- Buttons with Event Handlers -->
    <button onclick="showStatic()">Static Web Page</button>
    <button onclick="showDynamic()">Dynamic Web Page</button>

    <script>
        // Function for Static Web Page
        function showStatic() {
            document.getElementById("content").innerHTML =
            "<b>Static Web Page:</b><br><br>" +
            "A static web page shows the same content to every user.<br>" +
            "It is created using HTML and CSS only.<br>" +
            "Example: Simple portfolio website.";
        }

        // Function for Dynamic Web Page
        function showDynamic() {
            document.getElementById("content").innerHTML =
            "<b>Dynamic Web Page:</b><br><br>" +
            "A dynamic web page changes content based on user interaction.<br>" +
            "It uses JavaScript or server-side languages.<br>" +
            "Example: Login page, E-commerce website.";
        }
    </script>

</body>
</html>

