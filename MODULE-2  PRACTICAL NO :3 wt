B) Demonstrating different JavaScript Objects such as Window, Navigator, History, Location, Document
Code:-
<!DOCTYPE html>
<html>
<head>
<title>JavaScript Browser Objects</title>

<script>

function showWindow() {
    alert("Window Width: " + window.innerWidth);
}

function showNavigator() {
    document.getElementById("output").innerHTML =
    "Browser Name: " + navigator.appName +
    "<br>Browser Version: " + navigator.appVersion;
}

function showLocation() {
    document.getElementById("output").innerHTML =
    "Current URL: " + location.href;
}

function goBack() {
    history.back();
}

function changeText() {
    document.getElementById("output").innerHTML =
    "This text was changed using Document Object";
}

</script>

</head>

<body>

<h2>JavaScript Browser Objects Example</h2>

<button onclick="showWindow()">Window Object</button>
<button onclick="showNavigator()">Navigator Object</button>
<button onclick="showLocation()">Location Object</button>
<button onclick="goBack()">History Object</button>
<button onclick="changeText()">Document Object</button>

<p id="output">Click buttons to see results</p>

</body>
</html>


