AIM:- Write JavaScript code for Demonstrating different JavaScript Objects such as String, RegExp, Math, Date
Code:-
<!DOCTYPE html>
<html>
<head>
<title>JavaScript Objects Example</title>

<script>

function showObjects() {

    // String Object
    var text = "JavaScript Programming";
    var length = text.length;

    // RegExp Object
    var pattern = /JavaScript/;
    var result = pattern.test(text);

    // Math Object
    var randomNumber = Math.random();
    var squareRoot = Math.sqrt(25);

    // Date Object
    var today = new Date();

    document.getElementById("output").innerHTML =
    "String Length: " + length + "<br>" +
    "RegExp Test (JavaScript found?): " + result + "<br>" +
    "Random Number: " + randomNumber + "<br>" +
    "Square Root of 25: " + squareRoot + "<br>" +
    "Current Date and Time: " + today;

}

</script>

</head>

<body>

<h2>JavaScript Objects Demonstration</h2>

<button onclick="showObjects()">Show Results</button>

<p id="output"></p>

</body>
</html>

