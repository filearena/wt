c) Storing and Retrieving Cookies
Code:-
<!DOCTYPE html>
<html>
<head>
<title>Cookie Example</title>

<script>

// Store Cookie
function setCookie() {
    var username = document.getElementById("name").value;
    document.cookie = "username=" + username;
    alert("Cookie Stored Successfully");
}

// Retrieve Cookie
function getCookie() {
    var name = "username=";
    var cookies = document.cookie.split(";");

    for (var i = 0; i < cookies.length; i++) {
        var c = cookies[i].trim();

        if (c.indexOf(name) == 0) {
            var value = c.substring(name.length);
            document.getElementById("result").innerHTML =
            "Stored Username: " + value;
            return;
        }
    }

    document.getElementById("result").innerHTML = "Cookie not found";
}

</script>

</head>

<body>

<h2>Storing and Retrieving Cookies</h2>

Enter Name:
<input type="text" id="name">

<br><br>

<button onclick="setCookie()">Store Cookie</button>
<button onclick="getCookie()">Retrieve Cookie</button>

<p id="result"></p>

</body>
</html>

